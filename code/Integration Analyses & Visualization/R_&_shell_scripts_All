### R script for 3D PCA ###
# 1. Load matrix
expr <- read.delim("PCA_input_matrix.txt", header = TRUE, row.names = 1)
# 2. Log10 transformation (+1 to avoid log(0))
mat <- log10(expr + 1)
# 3. PCA (retain first 3 PCs)
pca <- prcomp(t(mat), rank. = 3)
# 4. Extract PCA coordinates
pca_df <- as.data.frame(pca$x)
# (Optional) add group information if available
# pca_df$Stage <- factor(stage_vector)
# 5. 3D PCA plot
plot_ly(
  pca_df,
  x = ~PC1,
  y = ~PC2,
  z = ~PC3,
  type = "scatter3d", mode = "markers", marker = list(size = 8)
)

