### R script for correlation heatmap ###
# 1. Load data
gene_df <- read.delim(
  "input.DESeq2NormCount.txt",
  row.names = 1
)
met_df <- read.delim(
  "input.metabolome.data.txt",
  row.names = 1
)
# 2. Transpose matrices (samples × features)
gene_mat <- t(gene_df)
met_mat  <- t(met_df)

# 3. Compute Pearson correlation and p-values
cor_mat  <- matrix(NA, ncol(met_mat), ncol(gene_mat))
pval_mat <- matrix(NA, ncol(met_mat), ncol(gene_mat))
rownames(cor_mat) <- colnames(met_mat)
colnames(cor_mat) <- colnames(gene_mat)
dimnames(pval_mat) <- dimnames(cor_mat)
for (i in seq_len(ncol(met_mat))) {
  for (j in seq_len(ncol(gene_mat))) {
    ct <- cor.test(met_mat[, i], gene_mat[, j], method = "pearson")
    cor_mat[i, j]  <- ct$estimate
    pval_mat[i, j] <- ct$p.value
  }
}
# 4. Plot correlation heat map
pdf("gene_metabolite_correlation_heatmap.pdf", width = 18, height = 6)
pheatmap(
  cor_mat,
  cluster_rows = TRUE,
  cluster_cols = TRUE,
  number_color = "black",
  fontsize_number = 6,
  fontsize_row = 10,
  fontsize_col = 10,
  color = colorRampPalette(
    c("dodgerblue", "lightblue", "lightyellow", "orange", "orangered")
  )(200),
  main = "Gene–Metabolite Correlation"
)
dev.off()

